# ==============================================================
# BookStore Microservice — Environment Variables
# ==============================================================
# Sao chép file này thành .env rồi điền giá trị thực:
#   cp .env.example .env
#
# docker-compose sẽ tự đọc file .env ở cùng thư mục.
# ==============================================================


# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Tài khoản superuser dùng chung cho tất cả microservices
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres            # ⚠️ Đổi thành password mạnh khi deploy
POSTGRES_DB=postgres                  # DB mặc định của container (không xóa)
POSTGRES_PORT=5432


# ── JWT ─────────────────────────────────────────────────────────────────────
# Secret key dùng để ký / xác minh JWT token.
# Phải GIỐNG NHAU ở tất cả services (customer, staff, api-gateway).
# ⚠️ Tạo key ngẫu nhiên khi deploy: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=bookstore-super-secret-jwt-2026


# ── Django Secret Keys (mỗi service dùng key riêng) ─────────────────────────
SECRET_KEY_CUSTOMER=customer-service-change-me-in-production
SECRET_KEY_BOOK=book-service-change-me-in-production
SECRET_KEY_CATALOG=catalog-service-change-me-in-production
SECRET_KEY_CART=cart-service-change-me-in-production
SECRET_KEY_STAFF=staff-service-change-me-in-production
SECRET_KEY_MANAGER=manager-service-change-me-in-production
SECRET_KEY_ORDER=order-service-change-me-in-production
SECRET_KEY_PAY=pay-service-change-me-in-production
SECRET_KEY_SHIP=ship-service-change-me-in-production
SECRET_KEY_COMMENT=comment-rate-change-me-in-production
SECRET_KEY_RECOMMENDER=recommender-change-me-in-production
SECRET_KEY_GATEWAY=api-gateway-change-me-in-production


# ── Database names (mỗi service có DB riêng — Database per Service) ──────────
DB_HOST=postgres               # hostname postgres service trong Docker network
DB_PORT=5432

DB_NAME_CUSTOMER=customer_db
DB_NAME_BOOK=book_db
DB_NAME_CATALOG=catalog_db
DB_NAME_CART=cart_db
DB_NAME_STAFF=staff_db
DB_NAME_MANAGER=manager_db
DB_NAME_ORDER=order_db
DB_NAME_PAY=pay_db
DB_NAME_SHIP=ship_db
DB_NAME_COMMENT=comment_rate_db
DB_NAME_RECOMMENDER=recommender_db


# ── Service URLs (internal Docker network) ───────────────────────────────────
# Dùng tên container làm hostname bên trong Docker network
CUSTOMER_SERVICE_URL=http://customer-service:8000
BOOK_SERVICE_URL=http://book-service:8000
CATALOG_SERVICE_URL=http://catalog-service:8000
CART_SERVICE_URL=http://cart-service:8000
ORDER_SERVICE_URL=http://order-service:8000
PAY_SERVICE_URL=http://pay-service:8000
SHIP_SERVICE_URL=http://ship-service:8000
COMMENT_RATE_URL=http://comment-rate-service:8000
RECOMMENDER_URL=http://recommender-ai-service:8000
STAFF_SERVICE_URL=http://staff-service:8000
MANAGER_SERVICE_URL=http://manager-service:8000


# ── Port mapping (host:container) ────────────────────────────────────────────
PORT_GATEWAY=8000
PORT_CUSTOMER=8001
PORT_BOOK=8002
PORT_CART=8003
PORT_STAFF=8004
PORT_MANAGER=8005
PORT_CATALOG=8006
PORT_ORDER=8007
PORT_PAY=8008
PORT_SHIP=8009
PORT_COMMENT=8010
PORT_RECOMMENDER=8011
PORT_POSTGRES=5432


# ── Debug / Production ───────────────────────────────────────────────────────
# Đặt thành False khi deploy production
DEBUG=True
